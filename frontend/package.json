{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --offline --port 8081",
    "start:online": "expo start --port 8081",
    "stop-metro": "powershell -NoProfile -Command \"$ports=8081,8082,8083; foreach ($p in $ports) { Get-NetTCPConnection -LocalPort $p -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --offline --port 8081"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "expo": "~54.0.34",
    "expo-barcode-scanner": "~13.0.1",
    "expo-camera": "~17.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-firebase-recaptcha": "^2.3.1",
    "expo-font": "~14.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-sms": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-google-places-autocomplete": "^2.6.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "1.20.1",
    "react-native-maps-directions": "^1.9.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "private": true,
  "devDependencies": {
    "@react-native-community/cli": "^20.0.2",
    "@react-native-community/cli-platform-android": "^20.0.2",
    "@react-native-community/cli-platform-ios": "^20.0.2"
  }
}
